{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "A child patient being assessed by a CHV.",
      "type": "object",
      "properties": {
        "age": { "type": "integer", "description": "Age in months (0-59)." },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "name": { "type": "string" }
          },
          "required": ["lat", "lng", "name"]
        },
        "chvId": { "type": "string", "description": "UID of the CHV who created the record." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["age", "gender", "location", "chvId", "createdAt"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "An AI-generated diagnosis for a patient.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "symptomSeverity": { "type": "object" },
        "diagnosis": {
          "type": "object",
          "properties": {
            "primaryDiagnosis": { "type": "string" },
            "secondaryDiagnosis": { "type": "string" },
            "confidence": { "type": "integer" },
            "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "reasoning": { "type": "string" },
            "keyFindings": { "type": "array", "items": { "type": "string" } },
            "treatment": {
              "type": "object",
              "properties": {
                "immediate": { "type": "string" },
                "medication": { "type": "string" },
                "monitoring": { "type": "string" }
              }
            },
            "redFlags": { "type": "array", "items": { "type": "string" } },
            "referralNeeded": { "type": "boolean" },
            "followUp": { "type": "string" }
          }
        },
        "malnutritionStatus": { "type": "string", "enum": ["normal", "MAM", "SAM", "at_risk", "not_assessed"] },
        "malnutritionConfidence": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "chvId": { "type": "string" }
      },
      "required": ["patientId", "diagnosis", "location", "timestamp", "chvId"]
    },
    "Alert": {
      "title": "Alert",
      "description": "An outbreak alert generated by the system.",
      "type": "object",
      "properties": {
        "disease": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "radius": { "type": "number", "description": "Radius in meters." },
        "caseCount": { "type": "integer" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" },
        "districtNotified": { "type": "boolean" }
      },
      "required": ["disease", "location", "radius", "caseCount", "severity", "timestamp", "resolved"]
    }
  },
  "firestore": {
    "/patients/{patientId}": { "schema": "Patient", "description": "Patient records." },
    "/diagnoses/{diagnosisId}": { "schema": "Diagnosis", "description": "AI diagnosis records." },
    "/alerts/{alertId}": { "schema": "Alert", "description": "Outbreak alerts." }
  }
}
